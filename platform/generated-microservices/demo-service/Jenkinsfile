#!/usr/bin/env groovy

// Microservice Bootstrap - Jenkins Pipeline
// Service: DemoService
// Generated: 2024

pipeline {
    agent any

    options {
        buildDiscarder(logRotator(numToKeepStr: '30', daysToKeepStr: '7'))
        timeout(time: 1, unit: 'HOURS')
        timestamps()
        ansiColor('xterm')
    }

    environment {
        SERVICE_NAME = 'demo-service'
        SERVICE_PORT = '8091'
        DOCKER_REGISTRY = 'docker.io'
        DOCKER_IMAGE = 'com-demo/demo-service'
        GIT_CREDENTIALS = 'github-credentials'
        MAVEN_HOME = '/usr/share/maven'
        JAVA_HOME = '/usr/lib/jvm/java-17-openjdk'
        COVERAGE_THRESHOLD = '80'
    }

    parameters {
        booleanParam(name: 'DEPLOY_TO_PROD', defaultValue: false, description: 'Deploy to production')
        string(name: 'RELEASE_VERSION', defaultValue: '1.0.0', description: 'Release version')
    }

    stages {
        stage('Checkout') {
            steps {
                script {
                    echo '═══════════════════════════════════════════'
                    echo 'Stage: SCM Checkout'
                    echo '═══════════════════════════════════════════'
                }
                checkout scm
                script {
                    env.GIT_COMMIT_SHORT = sh(returnStdout: true, script: 'git rev-parse --short HEAD').trim()
                    env.GIT_BRANCH = sh(returnStdout: true, script: 'git rev-parse --abbrev-ref HEAD').trim()
                    echo "✓ Checked out: ${GIT_COMMIT_SHORT} from ${GIT_BRANCH}"
                }
            }
        }

        stage('Validate') {
            steps {
                script {
                    echo '═══════════════════════════════════════════'
                    echo 'Stage: Input Validation'
                    echo '═══════════════════════════════════════════'
                }
                sh 'java -version'
                sh 'mvn -v'
                sh 'docker --version'
            }
        }

        stage('Build') {
            steps {
                script {
                    echo '═══════════════════════════════════════════'
                    echo 'Stage: Maven Build'
                    echo '═══════════════════════════════════════════'
                }
                sh 'bash scripts/build.sh'
            }
        }

        stage('Test') {
            steps {
                script {
                    echo '═══════════════════════════════════════════'
                    echo 'Stage: Unit Tests (JUnit)'
                    echo '═══════════════════════════════════════════'
                }
                sh 'bash scripts/test.sh'
            }
            post {
                always {
                    junit 'target/surefire-reports/**/*.xml'
                    publishHTML([
                        allowMissing: false,
                        alwaysLinkToLastBuild: true,
                        keepAll: true,
                        reportDir: 'target/surefireReports',
                        reportFiles: 'index.html',
                        reportName: 'Surefire Test Report'
                    ])
                }
            }
        }

        stage('Code Quality') {
            steps {
                script {
                    echo '═══════════════════════════════════════════'
                    echo 'Stage: JaCoCo Code Coverage Analysis'
                    echo '═══════════════════════════════════════════'
                }
                sh 'bash scripts/code-quality.sh'
            }
            post {
                always {
                    publishHTML([
                        allowMissing: false,
                        alwaysLinkToLastBuild: true,
                        keepAll: true,
                        reportDir: 'target/site/jacoco',
                        reportFiles: 'index.html',
                        reportName: 'JaCoCo Coverage Report'
                    ])
                }
            }
        }

        stage('Package') {
            steps {
                script {
                    echo '═══════════════════════════════════════════'
                    echo 'Stage: Create JAR Artifact'
                    echo '═══════════════════════════════════════════'
                }
                sh 'mvn package -DskipTests'
                script {
                    def jarFile = sh(returnStdout: true, script: 'find target -name "*.jar" -type f').trim()
                    echo "✓ JAR Created: ${jarFile}"
                }
            }
        }

        stage('Containerize') {
            when {
                anyOf {
                    branch 'main'
                    branch 'master'
                    branch 'develop'
                }
            }
            steps {
                script {
                    echo '═══════════════════════════════════════════'
                    echo 'Stage: Docker Image Build'
                    echo '═══════════════════════════════════════════'
                }
                sh 'bash scripts/docker-build.sh'
            }
        }

        stage('Deploy') {
            when {
                expression { params.DEPLOY_TO_PROD == true && env.GIT_BRANCH == 'main' }
            }
            steps {
                script {
                    echo '═══════════════════════════════════════════'
                    echo 'Stage: Deploy to Production'
                    echo '═══════════════════════════════════════════'
                    echo 'Deployment steps would be executed here...'
                }
            }
        }
    }

    post {
        always {
            script {
                echo "Pipeline completed with result: ${currentBuild.result}"
            }
            cleanWs()
        }
        failure {
            script {
                echo 'Pipeline failed! Check logs for details.'
                // Slack notification on failure would be added here
            }
        }
        success {
            script {
                echo '✓ Pipeline completed successfully!'
            }
        }
    }
}
